{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 10,
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "minLength": 50,
      "maxLength": 200
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "lastReviewedDate": {
      "type": "string",
      "format": "date-time"
    },
    "category": {
      "type": "string",
      "enum": [
        "Nutrition",
        "Sleep",
        "Mental Health",
        "Fitness",
        "Gut Health",
        "Longevity",
        "Research"
      ]
    },
    "tags": {
      "minItems": 1,
      "maxItems": 5,
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "author": {
      "default": "James Harper",
      "type": "string"
    },
    "heroImage": {
      "type": "string"
    },
    "readingTime": {
      "default": "5 min read",
      "type": "string"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "faqs": {
      "maxItems": 6,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string",
            "minLength": 5,
            "maxLength": 200
          },
          "answer": {
            "type": "string",
            "minLength": 10,
            "maxLength": 500
          }
        },
        "required": [
          "question",
          "answer"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "pubDate",
    "category",
    "tags"
  ]
}