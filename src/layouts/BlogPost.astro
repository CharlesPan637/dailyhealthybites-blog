---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';
import InstallPrompt from '../components/InstallPrompt.astro';
import blogPlaceholder from '../assets/blog-placeholder-1.jpg';

const { title, description, pubDate, updatedDate, lastReviewedDate, heroImage, author, readingTime, category, tags, faqs } = Astro.props;
const heroPath = heroImage || blogPlaceholder;
const displayName = (author || 'James Harper') + ', PhD';

const slugToCategoryClass = (cat: string) => {
  const map: Record<string, string> = {
    'Nutrition': 'nutrition',
    'Sleep': 'sleep',
    'Mental Health': 'mental-health',
    'Fitness': 'fitness',
    'Gut Health': 'gut-health',
    'Longevity': 'longevity',
    'Research': 'research',
  };
  return map[cat] || 'nutrition';
};

const allPosts = (await getCollection('blog')).filter((p) => !p.data.draft && p.data.title !== title);
const related = allPosts
  .sort((a, b) => {
    const aMatch = a.data.category === category ? 1 : 0;
    const bMatch = b.data.category === category ? 1 : 0;
    return bMatch - aMatch || b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  })
  .slice(0, 3);
const currentSlug = Astro.props.id || '';
const pageSlug = 'posts/' + currentSlug;
const displayDate = lastReviewedDate || updatedDate || pubDate;
---


<html lang="en">
<head>
  <BaseHead title={title + ' - Daily Healthy Bites'} description={description} image={heroPath.src} ogType="article" pubDate={pubDate} updatedDate={displayDate} />
  <SchemaOrg
    title={title}
    description={description}
    pubDate={pubDate}
    updatedDate={updatedDate}
    lastReviewedDate={lastReviewedDate}
    heroImage={heroPath.src}
    authorName={displayName}
    slug={pageSlug}
    category={category}
    faqs={faqs}
  />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" />
</head>
<body>
  <Header />
  <div id="reading-progress"></div>

  {/* Article page layout: sidebar + content */}
  <div class="article-page">
    {/* Sticky sidebar — desktop only */}
    <aside class="sidebar">
      <TableOfContents />

      {/* Author bio card */}
      <div class="sidebar-card author-card">
        <div class="author-card__avatar"></div>
        <p class="author-card__name">{displayName}</p>
        <p class="author-card__title">Microbiology & Immunology | 25+ Years in Science</p>
      </div>

      {/* Newsletter CTA in sidebar */}
      <div class="sidebar-card newsletter-card">
        <h4>Stay informed</h4>
        <p>Evidence-based health insights, delivered regularly.</p>
        <form class="newsletter-card__form" data-subscribe-form>
          <input type="email" placeholder="your@email.com" aria-label="Email address" required>
          <button type="submit">Subscribe</button>
          <span class="subscribe-msg" style="display:none;font-size:0.85rem;margin-top:6px"></span>
        </form>
      </div>
    </aside>

    {/* Main article content */}
    <main class="article-main">
      <article>
        {/* Hero Image with title overlaid */}
        <div class="article-hero">
          <Image
            src={heroPath}
            alt={title}
            format="webp"
            widths={[600, 900, 1200]}
            sizes="(max-width: 720px) 100vw, 80vw"
            class="article-hero__img"
          />
          <div class="article-hero__overlay">
            <span class={'tag-pill tag-pill--' + slugToCategoryClass(category)}>{category}</span>
            <h1 class="article-hero__title">{title}</h1>
            <div class="article-hero__meta">
              <span>{pubDate.toLocaleDateString('en-us', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              <span>&middot;</span>
              <span>{displayName}</span>
              <span>&middot;</span>
              <span>{readingTime}</span>
            </div>
  {lastReviewedDate && (
    <div class="article-hero__reviewed">Last reviewed: {lastReviewedDate.toLocaleDateString('en-us', { month: 'short', day: 'numeric', year: 'numeric' })}</div>
  )}

  {/* Share and Bookmark action buttons */}
  <div class="article-hero__actions">
    <button class="action-btn action-btn--share" onclick="handleShare(event, this)" aria-label="Share this article" title="Share">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
        <polyline points="16 6 12 2 8 6"/>
        <line x1="12" y1="2" x2="12" y2="15"/>
      </svg>
      <span>Share</span>
    </button>
    <button class="action-btn action-btn--bookmark" onclick="handleBookmark(event, this)" aria-label="Bookmark this article" title="Bookmark">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="bookmark-icon">
        <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
      </svg>
      <span>Save</span>
    </button>
  </div>
</div>
        </div>

        {/* Article Content */}
        <div class="prose">

          <slot />

          {/* Tags */}
          {tags && tags.length > 0 && (
            <div class="tags-row">
{tags.map(t => <span class={'tag-pill tag-pill--' + slugToCategoryClass(category)}>{t}</span>)}
            </div>
          )}

          {/* Author byline in article */}
          <div class="author-byline">
            <div class="author-byline__avatar"></div>
            <div>
              <p class="author-byline__name">{displayName}</p>
              <p class="author-byline__title">Microbiology & Immunology | 25+ Years in Science</p>
            </div>
          </div>

          {/* Related Posts */}
          {related.length > 0 && (
            <div class="related-posts">
              <h3 class="related-posts__heading">More Like This</h3>
              <div class="related-posts__grid">
                {related.map((post) => (
                  <a href={'/posts/' + post.id + '/'} class="related-card">
                    <div class="related-card__image">
                      <Image
                        src={post.data.heroImage || blogPlaceholder}
                        alt={post.data.title}
                        format="webp"
                        widths={[200, 400]}
                        sizes="200px"
                        class="related-card__img"
                      />
                    </div>
                    <div class="related-card__body">
                      <span class={'tag-pill tag-pill--' + slugToCategoryClass(post.data.category)}>{post.data.category}</span>
                      <h4 class="related-card__title">{post.data.title}</h4>
                      <span class="related-card__meta">{post.data.readingTime}</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

          {/* Newsletter CTA inline */}
          <div class="newsletter-cta">
            <h3 class="newsletter-cta__title">More like this. No fluff.</h3>
            <p class="newsletter-cta__sub">Evidence-based health insights, regularly. No hype, no supplement pitches.</p>
          </div>

          {/* Medical Disclaimer */}
          <div class="disclaimer-box">
            <span class="disclaimer-box__icon">&#x24D8;</span>
            This post is for informational purposes only and does not constitute medical advice. Always consult a qualified healthcare professional before making changes to your health routine.
          </div>
        </div>
      </article>
    </main>
  </div>

  <Footer />
  <InstallPrompt />

  <script>
    // Newsletter subscribe handler
    window.handleSubscribe = async function(form, event) {
      event.preventDefault();
      const input = form.querySelector('input[type="email"]');
      const msg = form.querySelector('.subscribe-msg');
      const email = input.value.trim();
      if (!email) return false;
      input.disabled = true;
      form.querySelector('button[type="submit"]').disabled = true;
      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({email})
        });
        const data = await res.json();
        if (data.status === 'ok' || data.status === 'already_subscribed') {
          msg.textContent = data.status === 'ok' ? "Thanks! You're subscribed." : "You're already subscribed.";
          msg.style.color = '#16a34a';
          input.value = '';
        } else {
          msg.textContent = data.error || 'Something went wrong.';
          msg.style.color = '#dc2626';
        }
      } catch(e) {
        msg.textContent = 'Network error. Please try again.';
        msg.style.color = '#dc2626';
      }
      msg.style.display = 'block';
      input.disabled = false;
      form.querySelector('button[type="submit"]').disabled = false;
      return false;
    };

    // Reading progress bar
    window.addEventListener('scroll', () => {
      const h = document.documentElement;
      const pct = (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100;
      const bar = document.getElementById('reading-progress');
      if (bar) bar.style.width = pct + '%';
    });

    // Share handler — copy link to clipboard
    // Synchronous for reliable user-gesture context across all browsers
    window.handleShare = function(e, btn) {
      e.stopPropagation();
      const url = window.location.href;
      const title = document.title.replace(' - Daily Healthy Bites', '');
      // Try Web Share API first (mobile native share sheet)
      if (navigator.share) {
        navigator.share({ title, url }).catch(function() {
          // User dismissed — silently ignore
        });
        return;
      }
      // Desktop: copy to clipboard synchronously
      copyToClipboard(url);
      showToast(btn, 'Link copied!');
    };

    function copyToClipboard(text) {
      var ta = document.createElement('textarea');
      ta.value = text;
      ta.style.cssText = 'position:fixed;top:0;left:0;width:1px;height:1px;opacity:0';
      document.body.appendChild(ta);
      ta.focus();
      ta.select();
      try { document.execCommand('copy'); } catch(e) {}
      document.body.removeChild(ta);
    }

    // Bookmark handler — localStorage-based reading list
    const BOOKMARKS_KEY = 'hdb_bookmarks';
    window.handleBookmark = function(e, btn) {
      e.stopPropagation();
      const slug = window.location.pathname.replace(/\/$/, '');
      const title = document.title.replace(' - Daily Healthy Bites', '');
      const bookmarks = JSON.parse(localStorage.getItem(BOOKMARKS_KEY) || '{}');
      const icon = btn.querySelector('.bookmark-icon');

      if (bookmarks[slug]) {
        delete bookmarks[slug];
        icon.setAttribute('fill', 'none');
        icon.style.fill = 'none';
        btn.classList.remove('bookmarked');
        btn.querySelector('span').textContent = 'Save';
        showToast(btn, 'Removed');
      } else {
        bookmarks[slug] = { title, savedAt: Date.now() };
        icon.setAttribute('fill', 'currentColor');
        icon.style.fill = 'currentColor';
        btn.classList.add('bookmarked');
        btn.querySelector('span').textContent = 'Saved';
        showToast(btn, 'Saved!');
      }
      localStorage.setItem(BOOKMARKS_KEY, JSON.stringify(bookmarks));
    };

    // Restore bookmark state on load
    document.addEventListener('DOMContentLoaded', () => {
      const slug = window.location.pathname.replace(/\/$/, '');
      const bookmarks = JSON.parse(localStorage.getItem(BOOKMARKS_KEY) || '{}');
      const btn = document.querySelector('.action-btn--bookmark');
      if (btn && bookmarks[slug]) {
        const icon = btn.querySelector('.bookmark-icon');
        icon.setAttribute('fill', 'currentColor');
        icon.style.fill = 'currentColor';
        btn.classList.add('bookmarked');
        btn.querySelector('span').textContent = 'Saved';
      }
    });

    // Toast notification — fixed at bottom-center of screen, no clipping issues
    function showToast(anchor, msg) {
      const existing = document.querySelector('.action-toast');
      if (existing) existing.remove();
      const toast = document.createElement('div');
      toast.className = 'action-toast';
      toast.textContent = msg;
      document.body.appendChild(toast);
      requestAnimationFrame(() => toast.classList.add('action-toast--visible'));
      setTimeout(() => {
        toast.classList.remove('action-toast--visible');
        setTimeout(() => toast.remove(), 300);
      }, 2000);
    }
  </script>
</body>
</html>

<style is:global>
  @import url('../styles/global.css');
</style>

<style is:inline>
  .article-page {
    max-width: var(--page-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr var(--max-width) 1fr;
    gap: var(--space-6);
    padding: 0 var(--space-4);
  }

  article { padding: 0; }

  .sidebar {
    grid-column: 1;
  }

  .article-main {
    grid-column: 2;
  }

  /* Sidebar card base */
  .sidebar-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: var(--space-4);
    margin-bottom: var(--space-4);
  }

  /* Author card in sidebar */
  .author-card {
    text-align: center;
  }
  .author-card__avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-accent-bg);
    margin: 0 auto var(--space-3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
  }
  .author-card__avatar::after {
    content: '\1F52C';
  }
  .author-card__name {
    font-weight: 600;
    font-size: 15px;
    margin: 0 0 var(--space-1);
  }
  .author-card__title {
    font-size: 12px;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0;
  }

  /* Newsletter card in sidebar */
  .newsletter-card h4 {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    margin: 0 0 var(--space-1);
  }
  .newsletter-card p {
    font-size: 13px;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
    line-height: 1.4;
    max-width: none;
  }
  .newsletter-card__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .newsletter-card__form input {
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    font-size: 13px;
    outline: none;
    background: var(--color-bg);
    width: 100%;
    box-sizing: border-box;
  }
  .newsletter-card__form input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 2px var(--color-accent-bg);
  }
  .newsletter-card__form button {
    padding: var(--space-2) var(--space-3);
    background: var(--color-accent);
    color: white;
    border: none;
    border-radius: var(--radius-card);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }
  .newsletter-card__form button:hover {
    background: var(--color-accent-hover);
  }

  /* Article hero — full-width image with title overlaid */
  .article-hero {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-hero);
    margin-top: var(--space-5);
    height: 460px;
  }

  .article-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: var(--radius-hero);
  }

  .article-hero__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-8) var(--space-6) var(--space-6);
    background: linear-gradient(transparent 0%, rgba(0,0,0,0.45) 40%, rgba(0,0,0,0.82) 100%);
    border-radius: 0 0 var(--radius-hero) var(--radius-hero);
  }

  .article-hero__title {
    font-family: var(--font-serif);
    font-size: 2.4rem;
    font-weight: 700;
    color: #fff;
    margin: var(--space-2) 0 var(--space-3);
    line-height: 1.18;
    text-shadow: 0 2px 8px rgba(0,0,0,0.35);
  }

  .article-hero__meta {
    font-family: var(--font-mono);
    font-size: 13px;
    color: rgba(255,255,255,0.82);
    display: flex;
    gap: var(--space-2);
    align-items: center;
    flex-wrap: wrap;
  }

  .article-hero__reviewed {
    font-family: var(--font-mono);
    font-size: 11px;
    color: rgba(255,255,255,0.6);
    margin-top: var(--space-1);
  }

  .prose {
    margin: 0;
    padding: var(--space-6) 0;
  }

  /* Prose-specific typography */
  .prose h1 { font-size: 2.5rem; margin-top: 0.5em; }
  .prose h2 { font-size: 1.75rem; margin-top: 2.5em; }
  .prose h3 { font-size: 1.375rem; margin-top: 2em; }
  .prose p { line-height: 1.7; margin-bottom: 1.5em; }
  .prose a { color: var(--color-science); text-decoration: underline; }
  .prose a:hover { color: var(--color-accent-hover); }
  .prose ul, .prose ol { padding-left: 1.5em; }
  .prose li { margin-bottom: 0.5em; }
  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-6) 0;
    font-size: 0.9375rem;
  }
  .prose th, .prose td {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    text-align: left;
  }
  .prose th {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-bg);
  }

  /* Tags at end */
  .tags-row {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-top: var(--space-6);
    margin-bottom: var(--space-6);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  /* FAQ section styling (in markdown content) */
  .prose .faq-h2 {
    font-size: 1.75rem;
    margin-top: 2.5em;
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  /* Key finding / In brief callout */
  .key-finding {
    background: var(--color-accent-bg);
    border-left: 4px solid var(--color-accent);
    border-radius: 0 var(--radius-card) var(--radius-card) 0;
    padding: var(--space-4) var(--space-5);
    margin: var(--space-5) 0;
  }
  .key-finding__label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-1);
  }
  .key-finding p:last-child {
    margin-bottom: 0;
  }

  /* The Bottom Line callout */
  .bottom-line {
    background: var(--color-surface);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-hero);
    padding: var(--space-5) var(--space-6);
    margin: var(--space-8) 0;
  }
  .bottom-line__label {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }
  .bottom-line p:last-child:not(:first-child) {
    margin-bottom: 0;
  }

  @media (max-width: 1024px) {
    .article-page {
      grid-template-columns: 1fr;
    }
    .sidebar { grid-column: 1; }
    .article-main { grid-column: 1; }
    .article-hero { height: 320px; }
    .article-hero__title { font-size: 1.8rem; }
    .prose { padding: var(--space-4) 0; }
  }

  /* Share & Bookmark action buttons */
  .article-hero__actions {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-3);
  }

  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: var(--radius-pill);
    background: rgba(0,0,0,0.25);
    backdrop-filter: blur(4px);
    color: rgba(255,255,255,0.85);
    font-size: 12px;
    font-family: var(--font-sans);
    cursor: pointer;
    transition: all 0.15s;
    line-height: 1;
  }

  .action-btn:hover {
    background: rgba(255,255,255,0.15);
    border-color: rgba(255,255,255,0.5);
    color: #fff;
  }

  .action-btn svg {
    flex-shrink: 0;
  }

  .action-btn--bookmark.bookmarked {
    background: rgba(45, 106, 79, 0.4);
    border-color: var(--color-accent);
  }

  /* Toast notification — fixed at bottom of viewport */
  .action-toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    z-index: 9999;
    background: var(--color-text);
    color: var(--color-bg);
    font-size: 13px;
    font-family: var(--font-sans);
    font-weight: 500;
    padding: 10px 20px;
    border-radius: var(--radius-pill);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.25s, transform 0.25s;
    white-space: nowrap;
    box-shadow: var(--shadow-lg);
  }

  .action-toast--visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media (max-width: 720px) {
    .article-hero { height: 260px; border-radius: var(--radius-card); }
    .article-hero__img { border-radius: var(--radius-card); }
    .article-hero__overlay { border-radius: 0 0 var(--radius-card) var(--radius-card); padding: var(--space-5) var(--space-4) var(--space-4); }
    .article-hero__title { font-size: 1.4rem; }
    .prose { padding: var(--space-4) 0; }
  }
</style>
