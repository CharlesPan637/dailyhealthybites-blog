---
import BaseHead from '../components/BaseHead.astro';
import SEOHead from '../components/SEOHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<html lang="en">
<head>
  <BaseHead title={'404 - ' + SITE_TITLE} description="Page not found" />
  <SEOHead title={'404 - ' + SITE_TITLE} description="Page not found" />
</head>
<body>
  <Header />
  <div id="reading-progress"></div>

  <main class="not-found-page">
    <div class="container">
      <h1>404 — Page Not Found</h1>
      <p class="lead">Sorry, we couldn't find that page.</p>
      <p>It might have been moved, renamed, or it never existed in the first place.</p>
      <a href="/" class="hero-cta" style="display:inline-block;margin-top:1.5rem">Go Home</a>
      <p style="margin-top:2rem">Looking for something specific? Try the <a href="/posts/">Blog</a> or <a href="/about/">About</a> page.</p>
    </div>
  </main>

  <Footer />
</body>
</html>

<style is:global>
  @import url('../styles/global.css');
</style>

<style is:inline>
  .not-found-page {
    text-align: center;
    padding: var(--space-10) var(--space-4);
  }
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .container h1 {
    font-size: 2.5rem;
    margin-bottom: var(--space-2);
  }
  .lead {
    font-size: 1.125rem;
    color: var(--color-text-muted);
  }
  @media (max-width: 720px) {
    .container h1 { font-size: 1.8rem; }
  }
</style>
